-- AntiFling functions (YOUR ORIGINAL)
local function enableAntiFling()
    if antiFlingActive then
        addLog("Anti-Fling is already enabled")
        return
    end
    
    antiFlingActive = true
    antiFlingIndicator.Visible = true
    
    task.wait(10)
    
    if not game.IsLoaded(game) then
        repeat task.wait() until game.IsLoaded(game)
    end
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "anti fling activated";
        Text = "script by Johan756#7155";
        Icon = "rbxthumb://type=Asset&id=5107182114&w=150&h=150";
        Duration = 16;
    })
    
    local function AntiFling()
        local HeartbeatLoop = nil
        
        for _, v in next, game:GetDescendants() do
            if v and v:IsA("Part") and v.Parent ~= player.Character and v.Anchored == false and v.Name == "HumanoidRootPart" then
                HeartbeatLoop = game:GetService("RunService").Heartbeat:Connect(function()
                    v.CustomPhysicalProperties = PhysicalProperties.new(0,0,0,0,0)
                    v.Velocity = Vector3.new(0,0,0)
                    v.RotVelocity = Vector3.new(0,0,0)
                    v.CanCollide = false
                    task.wait(1)
                end)
            end
        end
        
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.Died:Connect(function()
                if HeartbeatLoop then
                    HeartbeatLoop:Disconnect()
                    HeartbeatLoop = nil
                end
            end)
        end
        
        antiFlingHeartbeat = HeartbeatLoop
    end
    
    AntiFling()
    
    workspace.DescendantAdded:Connect(function(part)
        if antiFlingActive and part:IsA("Part") and part.Name == "HumanoidRootPart" and part.Parent ~= player.Character then
            task.wait(2)
            if antiFlingActive then
                if antiFlingHeartbeat then
                    antiFlingHeartbeat:Disconnect()
                    antiFlingHeartbeat = nil
                end
                AntiFling()
            end
        end
    end)
    
    addLog("Anti-Fling enabled - You are protected from being flung")
end

local function disableAntiFling()
    if not antiFlingActive then
        addLog("Anti-Fling is not enabled")
        return
    end
    
    if antiFlingHeartbeat then
        antiFlingHeartbeat:Disconnect()
        antiFlingHeartbeat = nil
    end
    
    antiFlingActive = false
    antiFlingIndicator.Visible = false
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Anti-Fling Deactivated",
        Text = "You are no longer protected from being flung",
        Duration = 3
    })
    
    addLog("Anti-Fling disabled - You can now be flung")
end

local function toggleAntiFling()
    if antiFlingActive then
        disableAntiFling()
    else
        enableAntiFling()
    end
end

-- Spectate functions
local function stopSpectating()
    if isSpectating then
        isSpectating = false
        if originalCameraSubject then
            camera.CameraSubject = originalCameraSubject
        else
            local character = player.Character
            if character and character:FindFirstChild("Humanoid") then
                camera.CameraSubject = character.Humanoid
            end
        end
        currentSpectateTarget = nil
        spectateIndicator.Visible = false
        addLog("Stopped spectating")
    end
end

local function startSpectating(targetPlayer)
    if not hasPermission(player, "Moderator") then
        addLog("Permission denied: You need Moderator+ rank to spectate")
        return false
    end
    
    if not targetPlayer or not targetPlayer.Character then
        addLog("Cannot spectate: Player has no character")
        return false
    end
    
    if isSpectating then
        stopSpectating()
    end
    
    originalCameraSubject = camera.CameraSubject
    currentSpectateTarget = targetPlayer
    
    local character = targetPlayer.Character
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        camera.CameraSubject = humanoid
        isSpectating = true
        
        spectateText.Text = "SPECTATING: " .. targetPlayer.Name
        spectateIndicator.Visible = true
        
        addLog(player.Name .. " [" .. getPlayerRank(player) .. "] started spectating " .. targetPlayer.Name .. " [" .. getPlayerRank(targetPlayer) .. "]")
        return true
    end
    return false
end

local function viewPlayer(targetPlayer)
    return startSpectating(targetPlayer)
end

