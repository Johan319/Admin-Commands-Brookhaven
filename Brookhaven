-- Bring Functions
local function messyFling(target)
    if flinging then return end
    flinging = true

    local targetChar = target.Character
    local myChar = player.Character
    if not targetChar or not myChar then flinging = false return end

    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot or not myRoot then flinging = false return end

    local originalCFrame = myRoot.CFrame
    local hum = myChar:FindFirstChildOfClass("Humanoid")
    if hum then
        hum:ChangeState(Enum.HumanoidStateType.Physics)
        hum.PlatformStand = true
    end

    myRoot.AssemblyLinearVelocity = Vector3.zero
    myRoot.AssemblyAngularVelocity = Vector3.zero

    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bp.D = 100; bp.P = 50000; bp.Parent = myRoot

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.D = 10; bg.P = 10000; bg.Parent = myRoot

    local bav = Instance.new("BodyAngularVelocity")
    bav.AngularVelocity = Vector3.new(math.random(-30,30), math.random(-60,60), math.random(-30,30))
    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bav.Parent = myRoot

    local connection
    local elapsed = 0

    connection = game:GetService("RunService").Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt
        targetChar = target.Character
        myChar = player.Character
        if not targetChar or not myChar then connection:Disconnect() flinging = false return end

        targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not myRoot then connection:Disconnect() flinging = false return end

        bp.Position = targetRoot.Position + Vector3.new(math.random(-2,2), math.random(0,3), math.random(-2,2))
        bg.CFrame = CFrame.Angles(math.random(-10,10)*0.05, math.random(-10,10)*0.05, math.random(-10,10)*0.05)

        local bv = Instance.new("BodyVelocity")
        bv.Velocity = Vector3.new(math.random(-200,200), math.random(50,300), math.random(-200,200))
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Parent = targetRoot
        game:GetService("Debris"):AddItem(bv, 0.05)

        local ba = Instance.new("BodyAngularVelocity")
        ba.AngularVelocity = Vector3.new(math.random(-40,40), math.random(-40,40), math.random(-40,40))
        ba.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        ba.Parent = targetRoot
        game:GetService("Debris"):AddItem(ba, 0.05)

        if elapsed >= 1 then
            connection:Disconnect()
            bp:Destroy(); bg:Destroy(); bav:Destroy()
            flinging = false
            if myRoot then
                myRoot.CFrame = originalCFrame
                myRoot.AssemblyLinearVelocity = Vector3.zero
                myRoot.AssemblyAngularVelocity = Vector3.zero
            end
            if hum then
                hum.PlatformStand = false
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
    end)
end

-- Dex/Explorer function (Admin rank)
local function openDexExplorer()
    local success, err = pcall(function()
        loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Dex-Explorer-DPP-73687"))()
    end)
    if success then
        addLog("Dex Explorer opened successfully (Admin+ rank required)")
    else
        addLog("Failed to load Dex Explorer: " .. tostring(err))
    end
end

-- Tool Teleport function (Moderator rank)
local function loadToolTeleport()
    if not hasPermission(player, "Moderator") then
        addLog("Permission denied: You need Moderator+ rank to use Tool Teleport")
        return false
    end
    
    local success, err = pcall(function()
        loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Teleport-tool-131546"))()
    end)
    
    if success then
        addLog("Tool Teleport loaded successfully (Moderator+ rank required)")
        return true
    else
        addLog("Failed to load Tool Teleport: " .. tostring(err))
        return false
    end
end

