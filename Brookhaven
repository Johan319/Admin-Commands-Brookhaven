-- ============================================
-- MAIN COMMAND EXECUTOR (used by BOTH chat and cmdbar2)
-- ============================================
local function executeCommand(msg)
    if msg:sub(1, 1) ~= prefix then return end
    local args = {}
    for arg in msg:sub(2):gmatch("%S+") do
        table.insert(args, arg)
    end
    local command = args[1] and args[1]:lower()
    local targetName = args[2]

    if command == "tp" or command == "goto" or command == "to" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        if targetName then
            local target = findPlayer(targetName)
            if target then
                teleportTo(target, player)
                commandCount = commandCount + 1
                counterLabel.Text = tostring(commandCount)
            else
                addLog("Player not found: " .. targetName)
            end
        else
            addLog("Usage: " .. prefix .. command .. " <player name>")
        end

    elseif command == "view" or command == "spectate" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        if targetName then
            local target = findPlayer(targetName)
            if target then
                if target == player then
                    addLog("You cannot spectate yourself!")
                else
                    viewPlayer(target)
                    commandCount = commandCount + 1
                    counterLabel.Text = tostring(commandCount)
                end
            else
                addLog("Player not found: " .. targetName)
            end
        else
            addLog("Usage: " .. prefix .. command .. " <player name>")
        end

    elseif command == "bring" then
        if not hasPermission(player, "Head Admin") then
            addLog("Permission denied: Head Admin required")
            return
        end
        if targetName then
            local target = findPlayer(targetName)
            if target then
                if target == player then
                    addLog("You cannot bring yourself!")
                else
                    messyFling(target)
                    commandCount = commandCount + 1
                    counterLabel.Text = tostring(commandCount)
                    addLog(player.Name .. " used bring on " .. target.Name)
                end
            else
                addLog("Player not found: " .. targetName)
            end
        else
            addLog("Usage: " .. prefix .. "bring <player name>")
        end

    elseif command == "dex" or command == "explorer" then
        if not hasPermission(player, "Admin") then
            addLog("Permission denied: Admin required")
            return
        end
        openDexExplorer()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)

    elseif command == "toolteleport" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        loadToolTeleport()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)

    elseif command == "antivoid" then
        if not hasPermission(player, "Admin") then
            addLog("Permission denied: Admin required")
            return
        end
        loadAntiVoid()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)

    elseif command == "antisit" then
        if not hasPermission(player, "Admin") then
            addLog("Permission denied: Admin required")
            return
        end
        toggleAntiSit()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)

    elseif command == "infjump" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        loadInfiniteJump()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)

    elseif command == "antifling" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        toggleAntiFling()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)

    elseif command == "cmdbar2" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        cmdbarFrame.Visible = not cmdbarFrame.Visible
        if cmdbarFrame.Visible then cmdbarInput:CaptureFocus() end

    elseif command == "serverinfo" or command == "info" then
        showServerInfo()
        commandCount = commandCount + 1
        counterLabel.Text = tostring(commandCount)
        addLog(player.Name .. " viewed server info")

    elseif command == "prefix" then
        if not hasPermission(player, "Moderator") then
            addLog("Permission denied: Moderator required")
            return
        end
        if targetName and #targetName == 1 then
            prefix = targetName
            updatePrefixDisplay()
            addLog("Prefix changed to: " .. prefix)
        else
            addLog("Usage: " .. prefix .. "prefix <single character>")
        end

    elseif command == "rejoin" then
        game:GetService("TeleportService"):Teleport(game.PlaceId)

    elseif command == "reset" then
        if player.Character then
            player.Character:BreakJoints()
            addLog(player.Name .. " reset their character")
        end

    elseif command == "cmds" or command == "commands" then
        showCommandsPanel()
        addLog(player.Name .. " viewed the commands list")
    end
end

